# Maintainer: hrdl <git@hrdl.eu>

pkgname=linux-pinenote-hrdl-git
pkgver=6.19.r349.g46028a0e2658
# Quartz64-A: bumped one past hrdl's prebuilt pkgrel=1 so this locally-built kernel
# (ships the rk3566-quartz64-a DTB + the patches below) wins pacman's version
# resolution. The meta package pins the kernel by pkgver only, so this still satisfies it.
pkgrel=2
pkgdesc="Linux kernel for PineNote (+ Quartz64-A DTB)"
arch=(aarch64)
url="https://git.sr.ht/~hrdl/linux"
license=(GPL-2.0-only)
makedepends=(git clang llvm lld bc)
backup=("etc/mkinitcpio.conf.d/${pkgname}.conf")
# Quartz64-A: pinned to the exact commit hrdl built the prebuilt 6.19.r349.g46028a0e2658
# from (it IS the current v6.19_pinenote tip), so the hardcoded pkgver stays
# correct and pinenote-hrdl-sway-meta's kernel pin resolves. This commit already
# carries Maximilian Weigand's rk3566-quartz64-a DTS + rockchip_ebc + tps65185.
# Fetched as sr.ht's snapshot tarball, NOT a git clone: makepkg pulls tarballs
# with curl (--retry 3 + resume), instead of a multi-GB, non-resumable
# full-history git clone that dies on any connection blip.
_commit=46028a0e2658877625568f2134e243b304966ef4
source=(
  "linux-pinenote-hrdl-${_commit}.tar.gz::https://git.sr.ht/~hrdl/linux/archive/${_commit}.tar.gz"
  0001-rockchip_ebc-fix-3win-build.patch
  0002-rockchip_ebc-temp_override-bypass-i2c-read.patch
  linux-pinenote-hrdl.preset
  mkinitcpio.conf)
# Quartz64-A: tarball -> SKIP (sr.ht snapshots aren't byte-stable). The preset sums are
# corrected to match the committed linux-pinenote-hrdl.preset — hrdl's commit
# recorded stale sums for it (the file was updated without `updpkgsums`).
sha256sums=('SKIP'
            '4b812e4594a6eeb6cf2ce7f51d5704053c7b60e6832b12231df086c21449b86a'
            '3ccade7920e60e9da9ce1fee545a2653590b440c5e55ad985df8e7267ebbcb00'
            '527955361f370a4e2266c7412a2fabe2f189382b829cb893dd9cd2d6c5f2b3b0'
            '70c78d88791f018ee55876270d61c0c99f7c0c1c0b871890380c95afbc90dc86')
b2sums=('SKIP'
        '1a90fc6066b97d14531c0064d0a4d24798aac83768d2f7e49484eb3ed3730167eef85ba3bb5cb35fbade8eeafc0b1eed2e546735c2c6b0679a00e0e31cd027aa'
        '0c25622153520f32c9b319f6abfbdca5f7ccd3611ce015d8c50a1bf927fa465ac5e43461aeac893c1e9db47e7f8cb0ca9b8ff43fa952c9ec48c0970a2c06be9c'
        'e6d7ec9d20b97956693ac082e67146227ccda0ca36407b08379417dd144a740b3e0c6f206fe97593ee64feb72dc18c130a9a3c7dc3749f7564b69a766ae09e1e'
        '397dbf8aa17aa66b66684f0560d1b619559a53bc52af31a4356bdac0bd89fa2d759b9779f3a1513e05caa586edb83dd0c70fab588a23170cb2245d64dc6ccee8')
provides=("linux=${pkgver}" KSMBD-MODULE WIREGUARD-MODULE)
conflicts=(linux-pinenote-hrdl)
options=(!strip !debug)

CARCH=aarch64

prepare() {
  cd "$srcdir/linux-$_commit"
  # Fix hrdl's 3WIN NEON build break (undeclared direct_mode + missing paren in the
  # fast path), then turn 3WIN on. Boot with rockchip_ebc.direct_mode=0 to actually use it.
  patch -Np1 -i "$srcdir/0001-rockchip_ebc-fix-3win-build.patch"
  # Quartz64-A bring-up: temp_override bypasses the flaky tps65185 i2c read,
  # killing the probe-time -110 -> refresh-thread hang.
  patch -Np1 -i "$srcdir/0002-rockchip_ebc-temp_override-bypass-i2c-read.patch"
  yes "" | make ARCH=arm64 pinenote_defconfig
  ./scripts/config --enable CONFIG_DRM_ROCKCHIP_EBC_3WIN_MODE
  yes "" | make ARCH=arm64 olddefconfig
}

build() {
  cd "$srcdir/linux-$_commit"
  yes "" | make ARCH=arm64 LLVM=1 Image Image.gz modules \
    rockchip/rk3566-pinenote-v1.{1,2}.dtb rockchip/rk3566-quartz64-a.dtb
}

package() {
  cd "$srcdir/linux-$_commit"
  _kernel_release=$(make -s kernelrelease)
  install -Dm644 arch/arm64/boot/Image -t "${pkgdir}/boot"
  install -Dm644 arch/arm64/boot/Image.gz "${pkgdir}/usr/lib/modules/${_kernel_release}/vmlinuz"
  install -Dm644 arch/arm64/boot/dts/rockchip/rk3566-pinenote-v1.{1,2}.dtb \
                 arch/arm64/boot/dts/rockchip/rk3566-quartz64-a.dtb -t "${pkgdir}/boot"
  make INSTALL_MOD_PATH="${pkgdir}/usr" modules_install
  sed -e "s/%KERNVER%/${_kernel_release}/g" -e "s/%PKGBASE%/${pkgname}/g" "${srcdir}/linux-pinenote-hrdl.preset" | install -Dm644 /dev/stdin "${pkgdir}/etc/mkinitcpio.d/${pkgname}.preset"
  install -Dm644 "${srcdir}/mkinitcpio.conf" "${pkgdir}/etc/mkinitcpio.conf.d/${pkgname}.conf"
  echo "${pkgname}" | install -Dm644 /dev/stdin "${pkgdir}/usr/lib/modules/${_kernel_release}/pkgbase"
}
