pkgname=brcm-firmware-pinenote
pkgver=0.1
pkgrel=1
pkgdesc="brcmfmac_sdio-firmware from the libreELEC for the Pine64 PineNote"
arch=(any)
license=(custom)
conflicts=(linux-firmware)
url="https://github.com/LibreELEC/brcmfmac_sdio-firmware"
source=(
  # "https://github.com/LibreELEC/brcmfmac_sdio-firmware/raw/88e46425ef489513c0b8bf7c2747d262367be1cc/BCM4345C0.hcd"
  "https://gitlab.com/kernel-firmware/linux-firmware/-/raw/8d82acd29b5c115f0b75b17907ebce712c6f2e22/brcm/brcmfmac43455-sdio.AW-CM256SM.txt"
  "https://gitlab.com/kernel-firmware/linux-firmware/-/raw/8d82acd29b5c115f0b75b17907ebce712c6f2e22/cypress/cyfmac43455-sdio.bin"
  "https://gitlab.com/kernel-firmware/linux-firmware/-/raw/8d82acd29b5c115f0b75b17907ebce712c6f2e22/cypress/cyfmac43455-sdio.clm_blob"
  "https://gitlab.com/kernel-firmware/linux-firmware/-/raw/main/LICENCE.cypress"
)
b2sums=('fb5bd566d7028fa3cf3d3057992716368734bcde83a87db86049ce8c6578bdaba7b0ba68ddf6a74c3057b8bee09b031b2e621df1f6c7e4e502522e29dcbe7582'
        '82ae91182661d34694b5c916b83f5db9bc8b737c67ff99a1081b549bcc5d3d64cb0b7f288750405b468bbe8c76d23be65e95837114a3e1af1e03b1ad73dc0c6c'
        '5d6b9c2a9cd9ebe9b2fca12c67741adc67a928b208738d31ba4e6dac5feaee7fa401f63ce15e834a2648cb81f6744e6a1bf5a7b8d0be443678224b47bc351fe9'
        '39cfe7678bb771de4672d8a8ac8b24142645ab93efef2ac3bac832716de924a264c98490d4f2a9d3c9c4d9f060f8d727da3836ab745930a224076390b171adf8')

package() {
  cd "${srcdir}"
  # install -Dm644 BCM4345C0.hcd -t "${pkgdir}/usr/lib/firmware/brcm"
  install -Dm644 cyfmac43455-sdio.{bin,clm_blob} -t "${pkgdir}/usr/lib/firmware/cypress"
  install -Dm644 brcmfmac43455-sdio.AW-CM256SM.txt -t "${pkgdir}/usr/lib/firmware/brcm"
  install -Dm644 LICENCE.cypress "${pkgdir}/usr/share/licenses/${pkgname}/LICENCE"

  ln -s ../cypress/cyfmac43455-sdio.bin "${pkgdir}/usr/lib/firmware/brcm/brcmfmac43455-sdio.pine64,pinenote-v1.2.bin"
  ln -s ../cypress/cyfmac43455-sdio.clm_blob "${pkgdir}/usr/lib/firmware/brcm/brcmfmac43455-sdio.clm_blob"
  ln -s brcmfmac43455-sdio.AW-CM256SM.txt "${pkgdir}/usr/lib/firmware/brcm/brcmfmac43455-sdio.pine64,pinenote-v1.2.txt"
}
